{
  "name": "weixin-household-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "WeChat household Codex gateway",
  "engines": {
    "node": ">=22.5.0"
  },
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "build": "tsc -p apps/server/tsconfig.json",
    "build:watch": "tsc -p apps/server/tsconfig.json --watch",
    "check": "tsc -p apps/server/tsconfig.json --noEmit",
    "setup": "node dist/apps/server/setup.js",
    "wechat:setup": "node dist/apps/server/setup.js",
    "accounts": "node dist/apps/server/accounts.js",
    "doctor": "node dist/apps/server/doctor.js",
    "backup": "node dist/apps/server/backup.js",
    "codex:configure": "node dist/apps/server/configure-codex.js",
    "codex:api-wrapper": "node dist/apps/server/codex-api-wrapper.js",
    "file:send": "node dist/apps/server/send-file.js",
    "start": "node dist/apps/server/index.js",
    "dev": "node --enable-source-maps --watch dist/apps/server/index.js"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/qrcode": "^1.5.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.21.0",
    "@zed-industries/codex-acp": "^0.12.0",
    "qrcode": "^1.5.4"
  }
}
